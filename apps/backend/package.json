    "@types/cors": "^2.8.0",
    "@types/pg": "^8.10.0",
    "@types/uuid": "^9.0.0",
    "@types/jest": "^29.5.0",
    "@types/supertest": "^6.0.0",
    "typescript": "^5.0.0",
    "ts-node-dev": "^2.0.0",
